# ============================================
# front-zapfarma — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# Do NOT commit your .env file to version control.

# ── Server (Express / SSR) ──────────────────
# Port the Node/Express server listens on (default: 4000)
PORT=4000

# ── Careers API ─────────────────────────────
# Storage backend for career applications: "memory" | "postgres"
CAREERS_STORAGE_MODE=memory

# PostgreSQL connection string (required when CAREERS_STORAGE_MODE=postgres)
CAREERS_DATABASE_URL=

# ── E2E / Playwright ───────────────────────
# Base URL used by Playwright E2E tests (default: http://localhost:4200)
BASE_URL=http://localhost:4200

# Set to "true" in CI environments
CI=

# ── Angular Environment (src/environments/environments.ts) ──
# The values below are compiled into the Angular bundle via
# src/environments/environments.ts. Update that file (or add
# file-replacement in project.json) when changing these for
# different deployment targets.
#
# API — Onboarding
# API_ONBOARDING=https://hom-apichat.zapfarma.com
#
# API — Production / Integrations
# API_PROD=https://api-integrations.zapfarma.com
#
# API — AI
# API_IA=https://api-ia.zapfarma.com/api
#
# Cal.com Scheduling
# CAL_USE_API_SCHEDULING=true
# CAL_DEMO_BASE_URL=https://cal.com/zapfarma/45min
# CAL_EVENT_TYPE_SLUG=45min
# CAL_USERNAME=zapfarma
# CAL_DURATION_MINUTES=45
#
# Local server URL (SSR)
# LOCALHOST=http://127.0.0.1:4000
#
# Webhooks (n8n)
# URL_WEBHOOK_TEST=https://n8ndocker.Zapfarmafy.com.br/webhook-test/experiencia
# URL_WEBHOOK_PROD=https://n8ndocker.Zapfarmafy.com.br/webhook/experiencia
#
# Careers
# CAREERS_API_URL=http://127.0.0.1:4000/api/careers
# CAREERS_RECIPIENT_EMAIL=contato@zapfarma.com
